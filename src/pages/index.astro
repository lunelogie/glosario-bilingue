---
// Datos quemados directamente en el componente
import glossaryRaw from '../data/glossary.json';
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Glosario Estadístico Trilingüe</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;0,8..60,600;1,8..60,300&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles/global.css" />
</head>
<body>
  <div class="app-shell">

    <aside class="sidebar">
      <div class="sidebar-header">
        {/* <div class="logo-mark">&Sigma;</div> */}
        <div class="logo-text">
          <span class="logo-title">Glosario</span>
          <span class="logo-sub">Estadístico Trilingüe</span>
        </div>
      </div>

      <div class="search-wrap">
        <svg class="search-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input type="text" id="search-input" class="search-input"
          placeholder="Buscar en inglés, español o francés…"
          autocomplete="off" spellcheck="false" />
      </div>

      <div class="filter-row">
        <button class="filter-btn active" data-filter="all">Todos</button>
        <button class="filter-btn" data-filter="Descriptive Statistics">Descriptiva</button>
        <button class="filter-btn" data-filter="Inferential Statistics">Inferencial</button>
      </div>

      <div class="term-count" id="term-count">Mostrando 31 de 31 entradas</div>

      <nav class="term-list" id="term-list">
        {glossaryRaw.map((term, i) => (
          <button
            class="term-item"
            data-index={String(i)}
            data-en={term.term_en.toLowerCase()}
            data-es={term.term_es.toLowerCase()}
            data-fr={term.term_fr.toLowerCase()}
            data-campo={term.campo}
          >
            <span class="term-num">{String(i + 1).padStart(2, '0')}</span>
            <span class="term-label">{term.term_en}</span>
			<span class="term-sep" style="color:rgba(255,255,255,0.2)">·</span>
			<span class="term-label term-label-es">{term.term_es}</span>
			<span class="term-sep" style="color:rgba(255,255,255,0.2)">·</span>
			<span class="term-label term-label-fr">{term.term_fr}</span>
            <span class={`term-badge ${term.campo === 'Descriptive Statistics' ? 'badge-desc' : 'badge-inf'}`}>
              {term.campo === 'Descriptive Statistics' ? 'DESC' : 'INF'}
            </span>
          </button>
        ))}
      </nav>
    </aside>

    <main class="main-panel" id="main-panel">
      <div class="welcome-state" id="welcome-state">
        <div class="welcome-symbol">&Sigma;</div>
        <h2 class="welcome-title">Selecciona un término</h2>
        <p class="welcome-sub">Elige una entrada del glosario para ver su ficha terminológica completa en los tres idiomas.</p>
      </div>

      <div class="entry-view" id="entry-view" style="display:none">
        <div class="entry-header">
          <div class="entry-meta-top">
            <span class="entry-number" id="entry-number">01</span>
            <div class="entry-titles">
              <span class="entry-title-en" id="entry-title-en"></span>
              <span class="entry-sep">&middot;</span>
              <span class="entry-title-es" id="entry-title-es"></span>
              <span class="entry-sep">&middot;</span>
              <span class="entry-title-fr" id="entry-title-fr"></span>
            </div>
          </div>
          <div class="entry-meta-tags">
            <span class="tag-symbol" id="entry-symbol"></span>
            <span class="tag-campo" id="entry-campo"></span>
          </div>
        </div>

        <div class="cards-grid">
          <div class="lang-card card-en">
            <div class="card-lang-header">
              <img class="flag" src="/public/reino-unido.png" alt="English" />
              <span class="lang-label">ENGLISH</span>
            </div>
            <h3 class="card-term" id="card-term-en"></h3>
            <p class="card-gram" id="card-gram-en"></p>
            <p class="card-phonetic" id="card-phonetic-en"></p>
            <div class="card-section-label">DEFINITION</div>
            <p class="card-def" id="card-def-en"></p>
            <a class="card-source" id="card-source-en" href="#" target="_blank" rel="noopener"></a>
          </div>

          <div class="lang-card card-es">
            <div class="card-lang-header">
              <img class="flag" src="/public/mundo.png" alt="Español" />
              <span class="lang-label">ESPAÑOL</span>
            </div>
            <h3 class="card-term" id="card-term-es"></h3>
            <p class="card-gram" id="card-gram-es"></p>
            <p class="card-phonetic" id="card-phonetic-es"></p>
            <div class="card-section-label">DEFINICIÓN</div>
            <p class="card-def" id="card-def-es"></p>
            <a class="card-source" id="card-source-es" href="#" target="_blank" rel="noopener"></a>
          </div>

          <div class="lang-card card-fr">
            <div class="card-lang-header">
              <img class="flag" src="/public/francia.png" alt="Français" />
              <span class="lang-label">FRANÇAIS</span>
            </div>
            <h3 class="card-term" id="card-term-fr"></h3>
            <p class="card-gram" id="card-gram-fr"></p>
            <p class="card-phonetic" id="card-phonetic-fr"></p>
            <div class="card-section-label">DÉFINITION</div>
            <p class="card-def" id="card-def-fr"></p>
            <a class="card-source" id="card-source-fr" href="#" target="_blank" rel="noopener"></a>
          </div>
        </div>
      </div>
    </main>
  </div>

  <script>
    const glossary = [{"term_en": "Correlation", "term_es": "Correlación", "term_fr": "Corrélation", "campo": "Inferential Statistics", "simbolo": "r / ρ", "gram_en": "noun (n.)", "gram_es": "sustantivo femenino (s.f.)", "gram_fr": "nom féminin (n.f.)", "def_en": "A statistical measure of the strength and direction of the linear relationship between two variables, ranging from −1 to +1.", "def_es": "Medida estadística de la fuerza y la dirección de la relación lineal entre dos variables, con valores entre −1 y +1.", "def_fr": "Mesure statistique de la force et de la direction de la relation linéaire entre deux variables, dont les valeurs vont de −1 à +1.", "fuente_def_en": "https://openstax.org/books/introductory-statistics/pages/12-3-the-regression-equation", "fuente_def_es": "https://dle.rae.es/correlaci%C3%B3n", "fuente_def_fr": "https://www.cnrtl.fr/definition/corr%C3%A9lation", "fon_en": "/ˌkɒr.əˈleɪ.ʃən/", "fon_es": "[ko.re.laˈsjon]", "fon_fr": "[kɔ.ʁe.la.sjɔ̃]", "fuente_fon_en": "https://www.merriam-webster.com/dictionary/correlation", "fuente_fon_es": "https://es.wiktionary.org/wiki/correlaci%C3%B3n", "fuente_fon_fr": "https://fr.wiktionary.org/wiki/corr%C3%A9lation", "comentario": ""}, {"term_en": "Correlation coefficient", "term_es": "Coeficiente de correlación", "term_fr": "Coefficient de corrélation", "campo": "Inferential Statistics", "simbolo": "r / ρ", "gram_en": "noun phrase (n.phr.)", "gram_es": "locución nominal masculina (loc.n.m.)", "gram_fr": "locution nominale féminine (loc.n.f.)", "def_en": "A numerical measure that quantifies the strength and direction of the linear relationship between two variables, typically ranging from -1 to +1.", "def_es": "Medida numérica que cuantifica la fuerza y dirección de la relación lineal entre dos variables, generalmente con valores entre -1 y +1.", "def_fr": "Mesure numérique qui quantifie la force et la direction de la relation linéaire entre deux variables, généralement comprise entre -1 et +1.", "fuente_def_en": "https://www.oxfordreference.com/display/10.1093/oi/authority.20110803095637394", "fuente_def_es": "https://iate.europa.eu/search#advanced?query=coeficiente+de+correlaci%C3%B3n&sl=ES", "fuente_def_fr": "https://www.cnrtl.fr/definition/corr%C3%A9lation", "fon_en": "/ˌkɒr.əˈleɪ.ʃən ˌkoʊ.ɪˈfɪʃ.ənt/", "fon_es": "[koe.fi.ˈsjen.te ðe ko.re.laˈsjon]", "fon_fr": "[kɔ.e.fi.sjɑ̃ də kɔ.ʁe.la.sjɔ̃]", "fuente_fon_en": "https://www.merriam-webster.com/dictionary/correlation", "fuente_fon_es": "https://es.wiktionary.org/wiki/correlaci%C3%B3n", "fuente_fon_fr": "https://fr.wiktionary.org/wiki/corr%C3%A9lation", "comentario": ""}, {"term_en": "Covariance", "term_es": "Covarianza", "term_fr": "Covariance", "campo": "Inferential Statistics", "simbolo": "Cov(X,Y) / sxy", "gram_en": "noun (n.)", "gram_es": "sustantivo femenino (s.f.)", "gram_fr": "nom féminin (n.f.)", "def_en": "A measure of the joint variability of two random variables, indicating how much they change together; positive values indicate a direct relationship, negative values an inverse one.", "def_es": "Medida de la variabilidad conjunta de dos variables aleatorias, que indica en qué medida cambian juntas; valores positivos indican una relación directa y valores negativos una relación inversa.", "def_fr": "Mesure de la variabilité conjointe de deux variables aléatoires, indiquant dans quelle mesure elles varient ensemble; les valeurs positives indiquent une relation directe, les valeurs négatives une relation inverse.", "fuente_def_en": "https://www.oxfordreference.com/display/10.1093/oi/authority.20110803095640834", "fuente_def_es": "https://iate.europa.eu/search#advanced?query=covarianza&sl=ES", "fuente_def_fr": "https://www.cnrtl.fr/definition/covariance", "fon_en": "/koʊˈveər.i.əns/", "fon_es": "[ko.βaˈɾjan.sa]", "fon_fr": "[ko.va.ʁjɑ̃s]", "fuente_fon_en": "https://www.merriam-webster.com/dictionary/covariance", "fuente_fon_es": "https://es.wiktionary.org/wiki/covarianza", "fuente_fon_fr": "https://fr.wiktionary.org/wiki/covariance", "comentario": ""}, {"term_en": "Degrees of freedom", "term_es": "Grados de libertad", "term_fr": "Degrés de liberté", "campo": "Inferential Statistics", "simbolo": "df / gl", "gram_en": "noun phrase (n.phr.)", "gram_es": "locución nominal masculina plural (loc.n.m.pl.)", "gram_fr": "locution nominale masculine (loc.n.m.)", "def_en": "The number of independent values that can vary in a statistical calculation; typically equal to the sample size minus the number of estimated parameters.", "def_es": "Número de valores independientes que pueden variar en un cálculo estadístico; generalmente igual al tamaño de la muestra menos el número de parámetros estimados.", "def_fr": "Nombre de valeurs indépendantes pouvant varier dans un calcul statistique; généralement égal à la taille de l'échantillon moins le nombre de paramètres estimés.", "fuente_def_en": "https://www.oxfordreference.com/display/10.1093/oi/authority.20110803095734874", "fuente_def_es": "https://iate.europa.eu/search#advanced?query=grados+de+libertad&sl=ES", "fuente_def_fr": "https://www.cnrtl.fr/definition/libert%C3%A9", "fon_en": "/dɪˈɡriːz əv ˈfriː.dəm/", "fon_es": "[ˈɡɾa.ðos ðe li.βeɾˈtað]", "fon_fr": "[de.ɡʁe də li.bɛʁ.te]", "fuente_fon_en": "https://www.merriam-webster.com/dictionary/degree", "fuente_fon_es": "https://es.wiktionary.org/wiki/grado", "fuente_fon_fr": "https://fr.wiktionary.org/wiki/degr%C3%A9", "comentario": ""}, {"term_en": "Deviation", "term_es": "Desviación", "term_fr": "Déviation", "campo": "Descriptive Statistics", "simbolo": "d", "gram_en": "noun (n.)", "gram_es": "sustantivo femenino (s.f.)", "gram_fr": "nom féminin (n.f.)", "def_en": "The difference between an individual data value and a reference value, typically the mean, indicating how far that value departs from the center of the distribution.", "def_es": "Diferencia entre un valor individual y un valor de referencia, habitualmente la media, que indica cuánto se aleja ese valor del centro de la distribución.", "def_fr": "Différence entre une valeur individuelle et une valeur de référence, généralement la moyenne, indiquant l'éloignement de cette valeur par rapport au centre de la distribution.", "fuente_def_en": "https://www.itl.nist.gov/div898/handbook/eda/section3/eda356.htm", "fuente_def_es": "https://dle.rae.es/desviaci%C3%B3n", "fuente_def_fr": "https://www.cnrtl.fr/definition/d%C3%A9viation", "fon_en": "/ˌdiː.viˈeɪ.ʃən/", "fon_es": "[des.βjaˈsjon]", "fon_fr": "[de.vja.sjɔ̃]", "fuente_fon_en": "https://www.merriam-webster.com/dictionary/deviation", "fuente_fon_es": "https://es.wiktionary.org/wiki/desviaci%C3%B3n", "fuente_fon_fr": "https://fr.wiktionary.org/wiki/d%C3%A9viation", "comentario": ""}, {"term_en": "Error", "term_es": "Error", "term_fr": "Erreur", "campo": "Inferential Statistics", "simbolo": "e / ε", "gram_en": "noun (n.)", "gram_es": "sustantivo masculino (s.m.)", "gram_fr": "nom masculin (n.m.)", "def_en": "The difference between an observed value and a true or expected value; in statistics, it refers to variability that cannot be explained by the model.", "def_es": "Diferencia entre un valor observado y un valor verdadero o esperado; en estadística, se refiere a la variabilidad que no puede ser explicada por el modelo.", "def_fr": "Différence entre une valeur observée et une valeur vraie ou attendue; en statistique, il désigne la variabilité qui ne peut pas être expliquée par le modèle.", "fuente_def_en": "https://www.oxfordreference.com/display/10.1093/oi/authority.20110803095825038", "fuente_def_es": "https://dle.rae.es/error", "fuente_def_fr": "https://www.cnrtl.fr/definition/erreur", "fon_en": "/ˈer.ər/", "fon_es": "[eˈroɾ]", "fon_fr": "[e.ʁœʁ]", "fuente_fon_en": "https://www.merriam-webster.com/dictionary/error", "fuente_fon_es": "https://es.wiktionary.org/wiki/error", "fuente_fon_fr": "https://fr.wiktionary.org/wiki/erreur", "comentario": ""}, {"term_en": "F-statistic", "term_es": "Estadístico F", "term_fr": "Statistique F", "campo": "Inferential Statistics", "simbolo": "F", "gram_en": "noun phrase (n.phr.)", "gram_es": "locución nominal masculina (loc.n.m.)", "gram_fr": "locution nominale féminine (loc.n.f.)", "def_en": "A ratio of two variances used in ANOVA and regression analysis to test whether group means differ significantly or whether a model explains a significant amount of variance.", "def_es": "Cociente de dos varianzas utilizado en ANOVA y análisis de regresión para determinar si las medias de los grupos difieren significativamente o si un modelo explica una cantidad significativa de varianza.", "def_fr": "Rapport de deux variances utilisé dans l'ANOVA et l'analyse de régression pour tester si les moyennes des groupes diffèrent significativement ou si un modèle explique une part significative de la variance.", "fuente_def_en": "https://www.oxfordreference.com/display/10.1093/oi/authority.20110803095853165", "fuente_def_es": "https://iate.europa.eu/search#advanced?query=estad%C3%ADstico+F&sl=ES", "fuente_def_fr": "https://www.cnrtl.fr/definition/statistique", "fon_en": "/ɛf stəˈtɪs.tɪk/", "fon_es": "[es.ta.ˈðis.ti.ko ˈe.fe]", "fon_fr": "[sta.tis.tik ɛf]", "fuente_fon_en": "https://www.merriam-webster.com/dictionary/statistic", "fuente_fon_es": "https://es.wiktionary.org/wiki/estad%C3%ADstico", "fuente_fon_fr": "https://fr.wiktionary.org/wiki/statistique", "comentario": ""}, {"term_en": "Hypothesis", "term_es": "Hipótesis", "term_fr": "Hypothèse", "campo": "Inferential Statistics", "simbolo": "H₀ / H₁", "gram_en": "noun (n.)", "gram_es": "sustantivo femenino (s.f.)", "gram_fr": "nom féminin (n.f.)", "def_en": "A testable statement or proposition about a population parameter, serving as the basis for statistical testing; includes the null hypothesis (H₀) and the alternative hypothesis (H₁).", "def_es": "Proposición o afirmación verificable sobre un parámetro poblacional, que sirve de base para la contrastación estadística; incluye la hipótesis nula (H₀) y la hipótesis alternativa (H₁).", "def_fr": "Proposition ou affirmation vérifiable sur un paramètre de population, servant de base aux tests statistiques; comprend l'hypothèse nulle (H₀) et l'hypothèse alternative (H₁).", "fuente_def_en": "https://www.oxfordreference.com/display/10.1093/oi/authority.20110803095959660", "fuente_def_es": "https://dle.rae.es/hip%C3%B3tesis", "fuente_def_fr": "https://www.cnrtl.fr/definition/hypoth%C3%A8se", "fon_en": "/haɪˈpɒθ.ɪ.sɪs/", "fon_es": "[i.ˈpo.te.sis]", "fon_fr": "[i.pɔ.tɛz]", "fuente_fon_en": "https://www.merriam-webster.com/dictionary/hypothesis", "fuente_fon_es": "https://es.wiktionary.org/wiki/hip%C3%B3tesis", "fuente_fon_fr": "https://fr.wiktionary.org/wiki/hypoth%C3%A8se", "comentario": ""}, {"term_en": "Hypothesis test", "term_es": "Prueba de hipótesis", "term_fr": "Test d'hypothèse", "campo": "Inferential Statistics", "simbolo": "H₀ / H₁", "gram_en": "noun phrase (n.phr.)", "gram_es": "locución nominal femenina (loc.n.f.)", "gram_fr": "locution nominale féminine (loc.n.f.)", "def_en": "A formal statistical procedure used to evaluate the evidence against a null hypothesis, leading to a decision to reject or fail to reject it based on sample data.", "def_es": "Procedimiento estadístico formal utilizado para evaluar la evidencia en contra de una hipótesis nula, que lleva a una decisión de rechazarla o no rechazarla en función de los datos muestrales.", "def_fr": "Procédure statistique formelle permettant d'évaluer les preuves contre une hypothèse nulle, conduisant à la décision de la rejeter ou non sur la base des données d'un échantillon.", "fuente_def_en": "https://www.oxfordreference.com/display/10.1093/oi/authority.20110803095959660", "fuente_def_es": "https://iate.europa.eu/search#advanced?query=prueba+de+hip%C3%B3tesis&sl=ES", "fuente_def_fr": "https://www.cnrtl.fr/definition/hypoth%C3%A8se", "fon_en": "/haɪˈpɒθ.ɪ.sɪs test/", "fon_es": "[ˈpɾwe.βa ðe i.ˈpo.te.sis]", "fon_fr": "[tɛst d‿i.pɔ.tɛz]", "fuente_fon_en": "https://www.merriam-webster.com/dictionary/hypothesis", "fuente_fon_es": "https://es.wiktionary.org/wiki/hip%C3%B3tesis", "fuente_fon_fr": "https://fr.wiktionary.org/wiki/hypoth%C3%A8se", "comentario": ""}, {"term_en": "Kurtosis", "term_es": "Curtosis", "term_fr": "Aplatissement / Kurtosis", "campo": "Descriptive Statistics", "simbolo": "γ₂ / β₂", "gram_en": "noun (n.)", "gram_es": "sustantivo femenino (s.f.)", "gram_fr": "nom masculin (n.m.)", "def_en": "A measure of the shape of a distribution's tails relative to a normal distribution; high kurtosis (leptokurtic) indicates heavier tails, low kurtosis (platykurtic) indicates lighter tails.", "def_es": "Medida de la forma de las colas de una distribución en relación con la distribución normal; una curtosis alta (leptocúrtica) indica colas más pesadas, y una baja (platicúrtica) indica colas más ligeras.", "def_fr": "Mesure de la forme des queues d'une distribution par rapport à la distribution normale; une kurtosis élevée (leptokurtique) indique des queues plus lourdes, une kurtosis faible (platykurtique) des queues plus légères.", "fuente_def_en": "https://www.itl.nist.gov/div898/handbook/eda/section3/eda35b.htm", "fuente_def_es": "https://iate.europa.eu/search#advanced?query=curtosis&sl=ES", "fuente_def_fr": "https://www.cnrtl.fr/definition/aplatissement", "fon_en": "/kɜːˈtoʊ.sɪs/", "fon_es": "[kuɾˈto.sis]", "fon_fr": "[kyʁ.to.zis]", "fuente_fon_en": "https://www.merriam-webster.com/dictionary/kurtosis", "fuente_fon_es": "https://es.wiktionary.org/wiki/curtosis", "fuente_fon_fr": "https://fr.wiktionary.org/wiki/kurtosis", "comentario": ""}, {"term_en": "Maximum", "term_es": "Máximo", "term_fr": "Maximum", "campo": "Descriptive Statistics", "simbolo": "max", "gram_en": "noun (n.)", "gram_es": "sustantivo masculino (s.m.)", "gram_fr": "nom masculin (n.m.)", "def_en": "The largest value in a dataset or within a defined range.", "def_es": "El valor más grande de un conjunto de datos o dentro de un rango definido.", "def_fr": "La plus grande valeur d'un e