    const searchInput = document.getElementById('search-input');
    const termList = document.getElementById('term-list');
    const termCount = document.getElementById('term-count');
    const welcomeState = document.getElementById('welcome-state');
    const entryView = document.getElementById('entry-view');
    const filterBtns = document.querySelectorAll('.filter-btn');
    const termItems = document.querySelectorAll('.term-item');

    let activeFilter = 'all';

    function normalizeStr(str) {
      return str.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
    }

    function filterTerms() {
      const query = normalizeStr(searchInput.value.trim());
      let visible = 0;
      let total = 0;

      termItems.forEach(item => {
        const campo = item.dataset.campo;
        const matchesFilter = activeFilter === 'all' || campo === activeFilter;
        if (matchesFilter) total++;

        const en = normalizeStr(item.dataset.en);
        const es = normalizeStr(item.dataset.es);
        const fr = normalizeStr(item.dataset.fr);
        const matchesSearch = !query || en.includes(query) || es.includes(query) || fr.includes(query);

        if (matchesSearch && matchesFilter) {
          item.style.display = '';
          visible++;
        } else {
          item.style.display = 'none';
        }
      });

      termCount.textContent = `Mostrando ${visible} de ${total} entradas`;
    }

    function safeHostname(url) {
      try { return new URL(url).hostname; } catch { return url; }
    }

    function showEntry(index) {
      const term = glossary[index];

      termItems.forEach(item => item.classList.remove('active'));
      const activeItem = termList.querySelector(`[data-index="${index}"]`);
      if (activeItem) activeItem.classList.add('active');

      document.getElementById('entry-number').textContent = String(index + 1).padStart(2, '0');
      document.getElementById('entry-title-en').textContent = term.term_en;
      document.getElementById('entry-title-es').textContent = term.term_es;
      document.getElementById('entry-title-fr').textContent = term.term_fr;
      document.getElementById('entry-symbol').textContent = term.simbolo;

      const campoEl = document.getElementById('entry-campo');
      campoEl.textContent = term.campo === 'Descriptive Statistics' ? 'DESCRIPTIVA' : 'INFERENCIAL';
      campoEl.className = 'tag-campo ' + (term.campo === 'Descriptive Statistics' ? 'campo-desc' : 'campo-inf');

      const langs = [
        { key: 'en', label: 'ENGLISH' },
        { key: 'es', label: 'ESPAÑOL' },
        { key: 'fr', label: 'FRANÇAIS' },
      ];

      langs.forEach(({ key }) => {
        document.getElementById(`card-term-${key}`).textContent = term[`term_${key}`];
        document.getElementById(`card-gram-${key}`).textContent = term[`gram_${key}`];
        document.getElementById(`card-phonetic-${key}`).textContent = term[`fon_${key}`];
        document.getElementById(`card-def-${key}`).textContent = term[`def_${key}`];
        const src = document.getElementById(`card-source-${key}`);
        src.textContent = 'Fuente: ' + safeHostname(term[`fuente_def_${key}`]);
        src.href = term[`fuente_def_${key}`];
      });

      welcomeState.style.display = 'none';
      entryView.style.display = 'block';
      entryView.classList.remove('fade-in');
      void entryView.offsetWidth;
      entryView.classList.add('fade-in');
    }

    termItems.forEach(item => {
      item.addEventListener('click', () => showEntry(parseInt(item.dataset.index)));
    });

    searchInput.addEventListener('input', filterTerms);

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeFilter = btn.dataset.filter;
        filterTerms();
      });
    });
  </script>
</body>
</html>