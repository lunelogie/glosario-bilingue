---
// Datos: fuente única (glossary.json). Se inyectan al cliente vía define:vars.
import glossaryRaw from '../data/glossary.json';

function badgeInfo(campo: string) {
  if (campo === 'Descriptive Statistics') return { cls: 'badge-desc', label: 'DESC' };
  if (campo === 'Inferential Statistics') return { cls: 'badge-inf', label: 'INF' };
  return { cls: 'badge-frase', label: 'FRASE' };
}
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Glosario Trilingüe</title>
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500&family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;0,8..60,600;1,8..60,300&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles/global.css" />
</head>
<body>
  <div class="app-shell">

    <aside class="sidebar">
      <div class="sidebar-header">
        <div class="logo-text">
          <span class="logo-title">Glosario</span>
          <span class="logo-sub" data-i18n="subtitle">Estadístico Trilingüe</span>
        </div>
        <div class="header-actions">
          <div class="lang-switch" id="lang-switch">
            <button class="lang-switch-btn active" data-lang="es">ES</button>
            <button class="lang-switch-btn" data-lang="en">EN</button>
            <button class="lang-switch-btn" data-lang="fr">FR</button>
          </div>
          <button id="theme-toggle" class="theme-toggle" title="Cambiar tema" aria-label="Cambiar tema">🌙</button>
        </div>
      </div>

      <div class="search-wrap">
        <svg class="search-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input type="text" id="search-input" class="search-input"
          data-i18n-placeholder="searchPlaceholder"
          placeholder="Buscar en inglés, español o francés…"
          autocomplete="off" spellcheck="false" />
      </div>

      <div class="filter-row">
        <button class="filter-btn active" data-filter="all" data-i18n="filterAll">Todos</button>
        <button class="filter-btn" data-filter="Descriptive Statistics" data-i18n="filterDesc">Descriptiva</button>
        <button class="filter-btn" data-filter="Inferential Statistics" data-i18n="filterInf">Inferencial</button>
        <button class="filter-btn" data-filter="Technical Phrases" data-i18n="filterPhrases">Frases</button>
      </div>

      <div class="term-count" id="term-count">Mostrando {glossaryRaw.length} de {glossaryRaw.length} entradas</div>

      <div class="action-row">
        <button id="quiz-start" class="action-btn action-btn-gold" data-i18n="actionQuiz">✦ Autoevaluación</button>
        <button id="stats-start" class="action-btn action-btn-outline" data-i18n="actionStats">📊 Estadísticas</button>
        <button id="add-start" class="action-btn action-btn-outline" data-i18n="actionAdd">➕ Agregar término</button>
      </div>

      <nav class="term-list" id="term-list">
        {glossaryRaw.map((term, i) => {
          const b = badgeInfo(term.campo);
          return (
            <button
              class="term-item"
              data-index={String(i)}
              data-en={term.term_en.toLowerCase()}
              data-es={term.term_es.toLowerCase()}
              data-fr={term.term_fr.toLowerCase()}
              data-campo={term.campo}
            >
              <span class="term-num">{String(i + 1).padStart(2, '0')}</span>
              <span class="term-label">{term.term_en}</span>
              <span class="term-sep" style="color:rgba(255,255,255,0.2)">·</span>
              <span class="term-label term-label-es">{term.term_es}</span>
              <span class="term-sep" style="color:rgba(255,255,255,0.2)">·</span>
              <span class="term-label term-label-fr">{term.term_fr}</span>
              <span class={`term-badge ${b.cls}`}>{b.label}</span>
            </button>
          );
        })}
      </nav>

      <div class="sidebar-credit"><span data-i18n="creditPrefix">Realizado por</span>: Selene Arcos y Julián Valencia</div>
    </aside>

    <main class="main-panel" id="main-panel">
      <div class="welcome-state" id="welcome-state">
        <div class="welcome-symbol">&Sigma;</div>
        <h2 class="welcome-title" data-i18n="welcomeTitle">Selecciona un término</h2>
        <p class="welcome-sub" data-i18n="welcomeSub">Elige una entrada del glosario para ver su ficha terminológica completa en los tres idiomas.</p>
      </div>

      <div class="entry-view" id="entry-view" style="display:none">
        <div class="entry-header">
          <div class="entry-meta-top">
            <span class="entry-number" id="entry-number">01</span>
            <div class="entry-titles">
              <span class="entry-title-en" id="entry-title-en"></span>
              <span class="entry-sep">&middot;</span>
              <span class="entry-title-es" id="entry-title-es"></span>
              <span class="entry-sep">&middot;</span>
              <span class="entry-title-fr" id="entry-title-fr"></span>
            </div>
          </div>
          <div class="entry-meta-tags">
            <span class="tag-symbol" id="entry-symbol"></span>
            <span class="tag-campo" id="entry-campo"></span>
            <span class="tag-nivel" id="entry-nivel" style="display:none"></span>
          </div>
        </div>

        <div class="entry-contexto" id="entry-contexto" style="display:none"></div>

        <div class="cards-grid">
          <div class="lang-card card-en">
            <div class="card-lang-header">
              <img class="flag" src="/reino-unido.png" alt="English" />
              <span class="lang-label">ENGLISH</span>
              <button class="play-btn" data-lang="en" data-voice="en-US" aria-label="Escuchar en inglés">🔊</button>
            </div>
            <h3 class="card-term" id="card-term-en"></h3>
            <p class="card-gram" id="card-gram-en"></p>
            <p class="card-phonetic" id="card-phonetic-en"></p>
            <div class="card-section-label" id="card-label-en">DEFINITION</div>
            <p class="card-def" id="card-def-en"></p>
            <a class="card-source" id="card-source-en" href="#" target="_blank" rel="noopener"></a>
          </div>

          <div class="lang-card card-es">
            <div class="card-lang-header">
              <img class="flag" src="/mundo.png" alt="Español" />
              <span class="lang-label">ESPAÑOL</span>
              <button class="play-btn" data-lang="es" data-voice="es-ES" aria-label="Escuchar en español">🔊</button>
            </div>
            <h3 class="card-term" id="card-term-es"></h3>
            <p class="card-gram" id="card-gram-es"></p>
            <p class="card-phonetic" id="card-phonetic-es"></p>
            <div class="card-section-label" id="card-label-es">DEFINICIÓN</div>
            <p class="card-def" id="card-def-es"></p>
            <a class="card-source" id="card-source-es" href="#" target="_blank" rel="noopener"></a>
          </div>

          <div class="lang-card card-fr">
            <div class="card-lang-header">
              <img class="flag" src="/francia.png" alt="Français" />
              <span class="lang-label">FRANÇAIS</span>
              <button class="play-btn" data-lang="fr" data-voice="fr-FR" aria-label="Escuchar en francés">🔊</button>
            </div>
            <h3 class="card-term" id="card-term-fr"></h3>
            <p class="card-gram" id="card-gram-fr"></p>
            <p class="card-phonetic" id="card-phonetic-fr"></p>
            <div class="card-section-label" id="card-label-fr">DÉFINITION</div>
            <p class="card-def" id="card-def-fr"></p>
            <a class="card-source" id="card-source-fr" href="#" target="_blank" rel="noopener"></a>
          </div>
        </div>
      </div>

      <div class="stats-view" id="stats-view" style="display:none"></div>
    </main>
  </div>

  <div class="quiz-overlay" id="quiz-overlay">
    <div class="quiz-card" id="quiz-card"></div>
  </div>

  <div class="add-overlay" id="add-overlay">
    <div class="add-card" id="add-card"></div>
  </div>

  <button id="vera-fab" class="vera-fab" aria-label="Abrir asistente Selian">
    <svg viewBox="0 0 40 40" class="vera-svg" aria-hidden="true">
      <defs>
        <linearGradient id="veraGradFab" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="var(--gold-bright)" />
          <stop offset="100%" stop-color="var(--gold)" />
        </linearGradient>
      </defs>
      <!-- orejitas de búho, apuntando hacia arriba -->
      <path d="M10 15 L13 3 L17 13 Z" fill="url(#veraGradFab)" />
      <path d="M30 15 L27 3 L23 13 Z" fill="url(#veraGradFab)" />
      <!-- cuerpo redondo (tapa la base de las orejas) -->
      <circle cx="20" cy="23" r="13" fill="url(#veraGradFab)" />
      <!-- pechera clara -->
      <ellipse cx="20" cy="29.5" rx="6" ry="4.5" fill="#fff" opacity="0.25" />
      <!-- ojos -->
      <g class="vera-eyes">
        <circle cx="14" cy="21" r="5.2" fill="#fff" />
        <circle cx="26" cy="21" r="5.2" fill="#fff" />
        <circle cx="14.5" cy="21.5" r="2.6" fill="#2b1a3d" />
        <circle cx="26.5" cy="21.5" r="2.6" fill="#2b1a3d" />
        <circle cx="15.5" cy="19.5" r="0.8" fill="#fff" />
        <circle cx="27.5" cy="19.5" r="0.8" fill="#fff" />
      </g>
      <!-- pico -->
      <path d="M18 25.5 L22 25.5 L20 29 Z" fill="#e8863f" />
    </svg>
  </button>

  <div class="vera-panel" id="vera-panel">
    <div class="vera-header">
      <div class="vera-header-info">
        <span class="vera-avatar">
          <svg viewBox="0 0 40 40" class="vera-svg" aria-hidden="true">
            <defs>
              <linearGradient id="veraGradHead" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="var(--gold-bright)" />
                <stop offset="100%" stop-color="var(--gold)" />
              </linearGradient>
            </defs>
            <path d="M10 15 L13 3 L17 13 Z" fill="url(#veraGradHead)" />
            <path d="M30 15 L27 3 L23 13 Z" fill="url(#veraGradHead)" />
            <circle cx="20" cy="23" r="13" fill="url(#veraGradHead)" />
            <ellipse cx="20" cy="29.5" rx="6" ry="4.5" fill="#fff" opacity="0.25" />
            <g class="vera-eyes">
              <circle cx="14" cy="21" r="5.2" fill="#fff" />
              <circle cx="26" cy="21" r="5.2" fill="#fff" />
              <circle cx="14.5" cy="21.5" r="2.6" fill="#2b1a3d" />
              <circle cx="26.5" cy="21.5" r="2.6" fill="#2b1a3d" />
              <circle cx="15.5" cy="19.5" r="0.8" fill="#fff" />
              <circle cx="27.5" cy="19.5" r="0.8" fill="#fff" />
            </g>
            <path d="M18 25.5 L22 25.5 L20 29 Z" fill="#e8863f" />
          </svg>
        </span>
        <div>
          <span class="vera-name">Selian</span>
          <span class="vera-tag" data-i18n="selianTag">Asistente del glosario</span>
        </div>
      </div>
      <button class="close-btn" id="vera-close" aria-label="Cerrar">✕</button>
    </div>
    <div class="vera-messages" id="vera-messages"></div>
    <form class="vera-input-row" id="vera-form">
      <input type="text" id="vera-input" data-i18n-placeholder="selianPlaceholder" placeholder="Pregúntame algo del glosario…" autocomplete="off" />
      <button type="submit" class="vera-send" aria-label="Enviar">➤</button>
    </form>
  </div>

