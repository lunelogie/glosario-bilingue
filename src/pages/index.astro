        selianQuizGo: 'Allons-y ! J\'ouvre le mode auto-évaluation 🎯',
        selianRandomIntro: (term, def) => `Je vous propose <strong>${term.term_fr}</strong> (${term.term_en} / ${term.term_es}) : ${def}`,
        selianDiffNotFound: (name) => `Je n'ai pas trouvé « ${name} » dans le glossaire. Pouvez-vous vérifier l'orthographe ?`,
        selianPronounceAsk: 'Dites-moi quel terme vous voulez entendre, par exemple « comment prononce-t-on variance ? »',
        selianPronounceResult: (term) => `<strong>${term.term_fr}</strong> se prononce ${term.fon_fr || '—'} (FR), ${term.fon_en || '—'} (EN), ${term.fon_es || '—'} (ES). J'ouvre sa fiche pour que vous puissiez utiliser le bouton 🔊.`,
        selianDefResult: (term, def) => `<strong>${term.term_fr}</strong> (${term.term_en} · ${term.term_es}) : ${def}`,
        selianNoExactSuggest: 'Je n\'ai pas trouvé de correspondance exacte, mais ceci pourrait vous aider :',
        selianNoMatch: 'Je n\'ai encore rien trouvé de lié à cela dans le glossaire. Essayez le nom d\'un terme statistique, ou tapez <em>aide</em> pour voir ce que je peux faire.',
        selianOpenStats: "J'ouvre le panneau complet…",
      },
    };

    // ── Patrones de reconocimiento de Selian por idioma ──────────────
    const SELIAN_PATTERNS = {
      es: {
        greeting: /^(hola|buenas|hey|hi|ola)\b/,
        help: /ayuda|que puedes hacer|comandos/,
        stats: /estadistica|cuantos terminos|cuantas entradas/,
        quiz: /quiz|autoevaluacion|examen|practicar/,
        random: /aleatorio|sorprend|cualquiera/,
        diff: /diferencia entre (.+?) y (.+)/i,
        pronounce: /pronunci|como se dice|como se pronuncia/,
        pronounceClean: /pronunci\w*|como se (dice|pronuncia)|\?/gi,
        whatIs: /qu[eé] es(?:\s+(?:la|el|un|una))?\s+(.+)/i,
        define: /defin[ei]\w*\s+(.+)/i,
      },
      en: {
        greeting: /^(hi|hello|hey|good morning|good afternoon)\b/,
        help: /help|what can you do|commands/,
        stats: /statistic|how many terms|how many entries/,
        quiz: /quiz|self.?test|practice/,
        random: /random|surprise|any term/,
        diff: /difference between (.+?) and (.+)/i,
        pronounce: /pronounce|how do you say/,
        pronounceClean: /pronounce\w*|how do you say|\?/gi,
        whatIs: /what\s+is(?:\s+(?:the|a|an))?\s+(.+)/i,
        define: /define\s+(.+)/i,
      },
      fr: {
        greeting: /^(salut|bonjour|coucou|hey|hi)\b/,
        help: /aide|que peux.tu faire|commandes/,
        stats: /statistique|combien de termes|combien d.entrees/,
        quiz: /quiz|auto.?evaluation|examen|pratiquer/,
        random: /aleatoire|au hasard|surpren/,
        diff: /difference entre (.+?) et (.+)/i,
        pronounce: /prononc|comment dit.on|comment prononce/,
        pronounceClean: /prononce\w*|comment (dit|prononce).on|\?/gi,
        whatIs: /qu.est.ce que(?:\s+(?:la|le|l’|l'|un|une))?\s+(.+)/i,
        define: /defini\w*\s+(.+)/i,
      },
    };

    let currentLang = 'es';
    try { currentLang = localStorage.getItem('glosario-ui-lang') || 'es'; } catch (e) {}

    function t(key) {
      return (I18N[currentLang] && I18N[currentLang][key] !== undefined) ? I18N[currentLang][key] : I18N.es[key];
    }

    function applyI18n() {
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.dataset.i18n;
        const val = t(key);
        if (typeof val === 'string') el.textContent = val;
      });
      document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
        const key = el.dataset.i18nPlaceholder;
        const val = t(key);
        if (typeof val === 'string') el.placeholder = val;
      });
      document.documentElement.lang = currentLang;
    }

    const searchInput = document.getElementById('search-input');
    const termList = document.getElementById('term-list');
    const termCount = document.getElementById('term-count');
    const welcomeState = document.getElementById('welcome-state');
    const entryView = document.getElementById('entry-view');
    const statsView = document.getElementById('stats-view');
    const filterBtns = document.querySelectorAll('.filter-btn');

    let activeFilter = 'all';
    let currentEntryIndex = null;

    function normalizeStr(str) {
      return str.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
    }

    function badgeFor(campo) {
      if (campo === 'Descriptive Statistics') return { cls: 'badge-desc', label: 'DESC' };
      if (campo === 'Inferential Statistics') return { cls: 'badge-inf', label: 'INF' };
      return { cls: 'badge-frase', label: 'FRASE' };
    }

    // ── RENDER SIDEBAR LIST (permite agregar términos en vivo) ──────
    function renderTermList() {
      termList.innerHTML = '';
      glossary.forEach((term, i) => {
        const b = badgeFor(term.campo);
        const btn = document.createElement('button');
        btn.className = 'term-item';
        btn.dataset.index = String(i);
        btn.dataset.en = term.term_en.toLowerCase();
        btn.dataset.es = term.term_es.toLowerCase();
        btn.dataset.fr = term.term_fr.toLowerCase();
        btn.dataset.campo = term.campo;
        btn.innerHTML = `
          <span class="term-num">${String(i + 1).padStart(2, '0')}</span>
          <span class="term-label">${term.term_en}</span>
          <span class="term-sep" style="color:rgba(255,255,255,0.2)">·</span>
          <span class="term-label term-label-es">${term.term_es}</span>
          <span class="term-sep" style="color:rgba(255,255,255,0.2)">·</span>
          <span class="term-label term-label-fr">${term.term_fr}</span>
          <span class="term-badge ${b.cls}">${b.label}</span>
        `;
        btn.addEventListener('click', () => showEntry(i));
        termList.appendChild(btn);
      });
      filterTerms();
    }

    function filterTerms() {
      const query = normalizeStr(searchInput.value.trim());
      let visible = 0;
      let total = 0;
      const items = termList.querySelectorAll('.term-item');

      items.forEach(item => {
        const campo = item.dataset.campo;
        const matchesFilter = activeFilter === 'all' || campo === activeFilter;
        if (matchesFilter) total++;

        const en = normalizeStr(item.dataset.en);
        const es = normalizeStr(item.dataset.es);
        const fr = normalizeStr(item.dataset.fr);
        const matchesSearch = !query || en.includes(query) || es.includes(query) || fr.includes(query);

        if (matchesSearch && matchesFilter) {
          item.style.display = '';
          visible++;
        } else {
          item.style.display = 'none';
        }
      });

      termCount.textContent = t('termCount')(visible, total);
    }

    function safeHostname(url) {
      try { return new URL(url).hostname; } catch { return url; }
    }

    function showEntry(index) {
      currentEntryIndex = index;
      const term = glossary[index];
      const esFrase = term.tipo === 'Frase';

      document.querySelectorAll('.term-item').forEach(item => item.classList.remove('active'));
      const activeItem = termList.querySelector(`[data-index="${index}"]`);
      if (activeItem) activeItem.classList.add('active');

      document.getElementById('entry-number').textContent = String(index + 1).padStart(2, '0');
      document.getElementById('entry-title-en').textContent = term.term_en;
      document.getElementById('entry-title-es').textContent = term.term_es;
      document.getElementById('entry-title-fr').textContent = term.term_fr;
      document.getElementById('entry-symbol').textContent = term.simbolo;

      const campoEl = document.getElementById('entry-campo');
      const campoLabel = term.campo === 'Descriptive Statistics' ? t('campoDesc')
        : term.campo === 'Inferential Statistics' ? t('campoInf') : t('campoFrase');
      const campoClass = term.campo === 'Descriptive Statistics' ? 'campo-desc'
        : term.campo === 'Inferential Statistics' ? 'campo-inf' : 'campo-frase';
      campoEl.textContent = campoLabel;
      campoEl.className = 'tag-campo ' + campoClass;

      const nivelEl = document.getElementById('entry-nivel');
      if (esFrase && term.nivel) {
        nivelEl.textContent = t('nivelPrefix') + ': ' + term.nivel;
        nivelEl.style.display = '';
      } else {
        nivelEl.style.display = 'none';
      }

      const contextoEl = document.getElementById('entry-contexto');
      if (esFrase && term.contexto_es) {
        contextoEl.innerHTML = `<strong>${t('contextoLabel')}:</strong> ${term.contexto_es}`;
        contextoEl.style.display = '';
      } else {
        contextoEl.style.display = 'none';
      }

      const langs = ['en', 'es', 'fr'];
      const labelDef = { en: 'DEFINITION', es: 'DEFINICIÓN', fr: 'DÉFINITION' };
      const labelFrase = { en: 'MEANING / CONTEXT', es: 'SIGNIFICADO / CONTEXTO', fr: 'SENS / CONTEXTE' };

      langs.forEach((key) => {
        document.getElementById(`card-term-${key}`).textContent = term[`term_${key}`];
        document.getElementById(`card-gram-${key}`).textContent = term[`gram_${key}`];
        document.getElementById(`card-phonetic-${key}`).textContent = term[`fon_${key}`] || '—';
        document.getElementById(`card-label-${key}`).textContent = esFrase ? labelFrase[key] : labelDef[key];
        document.getElementById(`card-def-${key}`).textContent = term[`def_${key}`];
        const src = document.getElementById(`card-source-${key}`);
        if (term[`fuente_def_${key}`]) {
          src.textContent = t('fuentePrefix') + ': ' + safeHostname(term[`fuente_def_${key}`]);
          src.href = term[`fuente_def_${key}`];
          src.style.display = '';
        } else {
          src.style.display = 'none';
        }
      });

      welcomeState.style.display = 'none';
      statsView.style.display = 'none';
      entryView.style.display = 'block';
      entryView.classList.remove('fade-in');
      void entryView.offsetWidth;
      entryView.classList.add('fade-in');
    }

    searchInput.addEventListener('input', filterTerms);

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeFilter = btn.dataset.filter;
        filterTerms();
      });
    });

    // ── PRONUNCIACIÓN (Web Speech API) ──────────────
    let cachedVoices = [];
    function refreshVoices() {
      if ('speechSynthesis' in window) cachedVoices = window.speechSynthesis.getVoices();
    }
    if ('speechSynthesis' in window) {
      refreshVoices();
      window.speechSynthesis.onvoiceschanged = refreshVoices;
    }

    function pickVoice(langCode) {
      if (!cachedVoices.length) refreshVoices();
      const base = langCode.split('-')[0];
      return (
        cachedVoices.find(v => v.lang.toLowerCase() === langCode.toLowerCase()) ||
        cachedVoices.find(v => v.lang.toLowerCase().startsWith(base)) ||
        null
      );
    }

    function speakTerm(text, langCode) {
      if (!('speechSynthesis' in window)) return;
      window.speechSynthesis.cancel();
      const utter = new SpeechSynthesisUtterance(text);
      utter.lang = langCode;
      const voice = pickVoice(langCode);
      if (voice) utter.voice = voice;
      utter.rate = 0.9;
      window.speechSynthesis.speak(utter);
    }

    document.querySelectorAll('.play-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const lang = btn.dataset.lang;
        const voice = btn.dataset.voice;
        const termEl = document.getElementById(`card-term-${lang}`);
        if (termEl && termEl.textContent) speakTerm(termEl.textContent, voice);
      });
    });

    // ── MODO OSCURO ──────────────────────────────────
    const themeToggle = document.getElementById('theme-toggle');
    function applyTheme(theme) {
      document.documentElement.setAttribute('data-theme', theme);
      themeToggle.textContent = theme === 'dark' ? '☀️' : '🌙';
      try { localStorage.setItem('glosario-theme', theme); } catch (e) {}
    }
    let savedTheme = 'light';
    try { savedTheme = localStorage.getItem('glosario-theme') || 'light'; } catch (e) {}
    applyTheme(savedTheme);
    themeToggle.addEventListener('click', () => {
      const current = document.documentElement.getAttribute('data-theme');
      applyTheme(current === 'dark' ? 'light' : 'dark');
    });

    // ── MODO AUTOEVALUACIÓN ──────────────────────────
    const quizOverlay = document.getElementById('quiz-overlay');
    const quizCard = document.getElementById('quiz-card');
    const quizStartBtn = document.getElementById('quiz-start');
    let quizPool = [];
    let quizIndex = 0;
    let quizScore = 0;
    let quizAnswered = false;

    function shuffle(arr) {
      const a = [...arr];
      for (let i = a.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [a[i], a[j]] = [a[j], a[i]];
      }
      return a;
    }

    function startQuiz() {
      quizPool = shuffle(glossary).slice(0, Math.min(10, glossary.length));
      quizIndex = 0;
      quizScore = 0;
      quizOverlay.classList.add('open');
      renderQuiz();
    }

    function closeQuiz() {
      quizOverlay.classList.remove('open');
      window.speechSynthesis && window.speechSynthesis.cancel();
    }

    function renderQuiz() {
      if (quizIndex >= quizPool.length) {
        quizCard.innerHTML = `
          <p class="quiz-eyebrow">${t('quizResult')}</p>
          <p class="quiz-result">${quizScore} / ${quizPool.length}</p>
          <p class="quiz-sub">${t('quizCorrect')}</p>
          <div class="quiz-footer" style="justify-content:center;">
            <button class="quiz-btn-outline" id="quiz-repeat">${t('quizRepeat')}</button>
            <button class="quiz-btn-outline" id="quiz-close-2">${t('quizClose')}</button>
          </div>
        `;
        document.getElementById('quiz-repeat').addEventListener('click', startQuiz);
        document.getElementById('quiz-close-2').addEventListener('click', closeQuiz);
        return;
      }
      quizAnswered = false;
      const entry = quizPool[quizIndex];
      const lang = ['en', 'es', 'fr'][Math.floor(Math.random() * 3)];
      const correctDef = entry[`def_${lang}`];
      const distractors = shuffle(glossary.filter(e => e.term_en !== entry.term_en))
        .slice(0, 3)
        .map(e => e[`def_${lang}`]);
      const options = shuffle([correctDef, ...distractors]);

      quizCard.innerHTML = `
        <p class="quiz-eyebrow">${t('quizQuestionOf')(quizIndex + 1, quizPool.length, t('langNames')[lang])}</p>
        <p class="quiz-result quiz-term-display">${entry[`term_${lang}`]}</p>
        <p class="quiz-sub">${t('quizQuestion')}</p>
        <div class="quiz-options" id="quiz-options"></div>
        <div class="quiz-footer">
          <span class="quiz-score">${t('quizScore')}: ${quizScore}</span>
          <button class="quiz-btn-outline" id="quiz-exit">${t('quizExit')}</button>
        </div>
      `;
      document.getElementById('quiz-exit').addEventListener('click', closeQuiz);
      const optContainer = document.getElementById('quiz-options');
      options.forEach(opt => {
        const btn = document.createElement('button');
        btn.className = 'quiz-opt';
        btn.textContent = opt;
        btn.addEventListener('click', () => {
          if (quizAnswered) return;
          quizAnswered = true;
          const isCorrect = opt === correctDef;
          btn.classList.add(isCorrect ? 'correct' : 'wrong');
          if (isCorrect) quizScore++;
          else {
            [...optContainer.children].forEach(c => {
              if (c.textContent === correctDef) c.classList.add('correct');
            });
          }
          setTimeout(() => { quizIndex++; renderQuiz(); }, 1100);
        });
        optContainer.appendChild(btn);
      });
    }

    quizStartBtn.addEventListener('click', startQuiz);
    quizOverlay.addEventListener('click', (e) => {
      if (e.target.id === 'quiz-overlay') closeQuiz();
    });

    // ── ESTADÍSTICAS (panel tipo dashboard, del prototipo Java) ──────
    const statsStartBtn = document.getElementById('stats-start');

    function computeStats() {
      const total = glossary.length;
      const palabras = glossary.filter(t => t.tipo !== 'Frase');
      const frases = glossary.filter(t => t.tipo === 'Frase');
      const desc = palabras.filter(t => t.campo === 'Descriptive Statistics').length;
      const inf = palabras.filter(t => t.campo === 'Inferential Statistics').length;

      const porCategoria = {};
      glossary.forEach(t => {
        const cat = (t.gram_es || '').split(/[,/]/)[0].trim() || '—';
        porCategoria[cat] = (porCategoria[cat] || 0) + 1;
      });

      return { total, nPalabras: palabras.length, nFrases: frases.length, desc, inf, porCategoria };
    }

    function pct(n, d) { return d === 0 ? '0.0%' : (n * 100 / d).toFixed(1) + '%'; }

    function renderStats() {
      const s = computeStats();
      const catRows = Object.entries(s.porCategoria)
        .sort((a, b) => b[1] - a[1])
        .map(([cat, n]) => `<tr><td>${cat}</td><td>${n}</td></tr>`).join('');

      statsView.innerHTML = `
        <div class="stats-header">
          <h2>${t('statsTitle')}</h2>
          <p class="stats-sub">${t('statsSub')}</p>
        </div>

        <div class="stats-cards">
          <div class="stat-card"><span class="stat-n">${s.total}</span><span class="stat-l">${t('statTotal')}</span></div>
          <div class="stat-card stat-c-green"><span class="stat-n">${s.nPalabras}</span><span class="stat-l">${t('statWords')}</span></div>
          <div class="stat-card stat-c-amber"><span class="stat-n">${s.nFrases}</span><span class="stat-l">${t('statPhrases')}</span></div>
          <div class="stat-card stat-c-blue"><span class="stat-n">${s.desc}</span><span class="stat-l">${t('statDesc')}</span></div>
          <div class="stat-card stat-c-purple"><span class="stat-n">${s.inf}</span><span class="stat-l">${t('statInf')}</span></div>
        </div>

        <h3 class="stats-subtitle">${t('statsByField')}</h3>
        <table class="stats-table">
          <thead><tr><th>${t('colField')}</th><th>${t('colQty')}</th><th>${t('colPct')}</th></tr></thead>
          <tbody>
            <tr><td>${t('statDesc')}</td><td>${s.desc}</td><td>${pct(s.desc, s.nPalabras)}</td></tr>
            <tr><td>${t('statInf')}</td><td>${s.inf}</td><td>${pct(s.inf, s.nPalabras)}</td></tr>
          </tbody>
        </table>

        <h3 class="stats-subtitle">${t('statsByType')}</h3>
        <table class="stats-table">
          <thead><tr><th>${t('colType')}</th><th>${t('colQty')}</th><th>${t('colPct')}</th></tr></thead>
          <tbody>
            <tr><td>${t('rowWord')}</td><td>${s.nPalabras}</td><td>${pct(s.nPalabras, s.total)}</td></tr>
            <tr><td>${t('rowPhrase')}</td><td>${s.nFrases}</td><td>${pct(s.nFrases, s.total)}</td></tr>
          </tbody>
        </table>

        <h3 class="stats-subtitle">${t('statsByGram')}</h3>
        <table class="stats-table">
          <thead><tr><th>${t('colCat')}</th><th>${t('colQty')}</th></tr></thead>
          <tbody>${catRows}</tbody>
        </table>

        <h3 class="stats-subtitle">${t('statsProportion')}</h3>
        <div class="stats-bar">
          <div class="stats-bar-desc" style="width:${s.nPalabras ? (s.desc * 100 / s.nPalabras) : 0}%">${s.desc ? t('statDesc') + ' ' + s.desc : ''}</div>
          <div class="stats-bar-inf" style="width:${s.nPalabras ? (s.inf * 100 / s.nPalabras) : 0}%">${s.inf ? t('statInf') + ' ' + s.inf : ''}</div>
        </div>
      `;
    }

    statsStartBtn.addEventListener('click', () => {
      welcomeState.style.display = 'none';
      entryView.style.display = 'none';
      statsView.style.display = 'block';
      renderStats();
      document.querySelectorAll('.term-item').forEach(item => item.classList.remove('active'));
    });

    // ── AGREGAR TÉRMINO (formulario, del prototipo Java) ─────────────
    const addOverlay = document.getElementById('add-overlay');
    const addCard = document.getElementById('add-card');
    const addStartBtn = document.getElementById('add-start');
    const STORAGE_KEY = 'glosario-terminos-agregados';

    function loadStoredTerms() {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return;
        const stored = JSON.parse(raw);
        stored.forEach(t => glossary.push(t));
      } catch (e) {}
    }

    function persistAddedTerms() {
      try {
        const original = glossaryData.length;
        const added = glossary.slice(original);
        localStorage.setItem(STORAGE_KEY, JSON.stringify(added));
      } catch (e) {}
    }

    function renderAddForm(msg) {
      addCard.innerHTML = `
        <div class="add-header">
          <h2>${t('addTitle')}</h2>
          <button class="close-btn" id="add-close" aria-label="Cerrar">✕</button>
        </div>
        <p class="add-sub">${t('addSub')}</p>
        <form id="add-form" class="add-form">
          <div class="add-section-label">${t('addSectionEs')}</div>
          <label>${t('addTermEs')}<input required name="term_es" type="text"></label>
          <label>${t('addDefEs')}<textarea required name="def_es" rows="2"></textarea></label>
          <div class="add-row-2">
            <label>${t('addGram')}<input name="gram_es" type="text" placeholder="sustantivo femenino (s.f.)"></label>
            <label>${t('addSymbol')}<input name="simbolo" type="text" placeholder="σ, x̄, p…"></label>
          </div>
          <label>${t('addField')}
            <select name="campo">
              <option value="Descriptive Statistics">${t('addFieldDesc')}</option>
              <option value="Inferential Statistics">${t('addFieldInf')}</option>
              <option value="Technical Phrases">${t('addFieldPhrase')}</option>
            </select>
          </label>

          <div class="add-section-label">${t('addSectionEn')}</div>
          <label>${t('addTermEn')}<input name="term_en" type="text"></label>
          <label>${t('addDefEn')}<textarea name="def_en" rows="2"></textarea></label>

          <div class="add-section-label">${t('addSectionFr')}</div>
          <label>${t('addTermFr')}<input name="term_fr" type="text"></label>
          <label>${t('addDefFr')}<textarea name="def_fr" rows="2"></textarea></label>

          <p class="add-error" id="add-error"></p>
          <p class="add-ok" id="add-ok">${msg || ''}</p>
          <div class="add-actions">
            <button type="submit" class="action-btn action-btn-gold">${t('addSave')}</button>
            <button type="button" class="action-btn action-btn-outline" id="add-clear">${t('addClear')}</button>
          </div>
        </form>
      `;
      document.getElementById('add-close').addEventListener('click', closeAdd);
      document.getElementById('add-clear').addEventListener('click', () => renderAddForm());

      document.getElementById('add-form').addEventListener('submit', (e) => {
        e.preventDefault();
        const fd = new FormData(e.target);
        const termEs = (fd.get('term_es') || '').trim();
        const defEs = (fd.get('def_es') || '').trim();
        const errorEl = document.getElementById('add-error');
        if (!termEs || !defEs) {
          errorEl.textContent = t('addErrorRequired');
          return;
        }
        errorEl.textContent = '';

        const nuevo = {
          term_en: (fd.get('term_en') || '').trim() || '—',
          term_es: termEs,
          term_fr: (fd.get('term_fr') || '').trim() || '—',
          campo: fd.get('campo'),
          simbolo: (fd.get('simbolo') || '').trim() || '—',
          tipo: fd.get('campo') === 'Technical Phrases' ? 'Frase' : 'Palabra',
          gram_en: '', gram_es: (fd.get('gram_es') || '').trim() || '—', gram_fr: '',
          def_en: (fd.get('def_en') || '').trim() || '—',
          def_es: defEs,
          def_fr: (fd.get('def_fr') || '').trim() || '—',
          fuente_def_en: '', fuente_def_es: '', fuente_def_fr: '',
          fon_en: '', fon_es: '', fon_fr: '',
          fuente_fon_en: '', fuente_fon_es: '', fuente_fon_fr: '',
          comentario: 'Agregado manualmente por el usuario.'
        };

        glossary.push(nuevo);
        persistAddedTerms();
        renderTermList();
        renderAddForm(t('addSuccess')(termEs));
      });
    }

    function openAdd() {
      renderAddForm();
      addOverlay.classList.add('open');
    }
    function closeAdd() {
      addOverlay.classList.remove('open');
    }

    addStartBtn.addEventListener('click', openAdd);
    addOverlay.addEventListener('click', (e) => {
      if (e.target.id === 'add-overlay') closeAdd();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') { closeQuiz(); closeAdd(); }
    });

    // ── VERA: ASISTENTE VIRTUAL SIMULADA (sin IA, sin API) ───────────
    const veraFab = document.getElementById('vera-fab');
    const veraPanel = document.getElementById('vera-panel');
    const veraClose = document.getElementById('vera-close');
    const veraMessages = document.getElementById('vera-messages');
    const veraForm = document.getElementById('vera-form');
    const veraInput = document.getElementById('vera-input');

    function veraNorm(str) {
      return (str || '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').trim();
    }

    function veraFindTerm(query) {
      const q = veraNorm(query);
      if (!q) return null;
      return glossary.find(t =>
        veraNorm(t.term_es) === q || veraNorm(t.term_en) === q || veraNorm(t.term_fr) === q
      ) || glossary.find(t =>
        veraNorm(t.term_es).includes(q) || veraNorm(t.term_en).includes(q) || veraNorm(t.term_fr).includes(q) ||
        q.includes(veraNorm(t.term_es)) || q.includes(veraNorm(t.term_en))
      ) || null;
    }

    function veraFindAllMatches(query) {
      const q = veraNorm(query);
      return glossary.filter(t =>
        veraNorm(t.term_es).includes(q) || veraNorm(t.term_en).includes(q) || veraNorm(t.term_fr).includes(q) ||
        veraNorm(t.def_es || '').includes(q)
      ).slice(0, 5);
    }

    function veraAddMessage(who, html) {
      const div = document.createElement('div');
      div.className = 'vera-msg vera-msg-' + who;
      div.innerHTML = html;
      veraMessages.appendChild(div);
      veraMessages.scrollTop = veraMessages.scrollHeight;
    }

    function veraSuggestionRow(matches) {
      if (!matches.length) return '';
      const chips = matches.map((term) => {
        const realIndex = glossary.indexOf(term);
        const label = term[`term_${currentLang}`] || term.term_es;
        return `<button class="vera-chip" data-goto="${realIndex}">${label}</button>`;
      }).join('');
      return `<div class="vera-chips">${chips}</div>`;
    }

    function veraRespond(rawText) {
      const text = veraNorm(rawText);
      const p = SELIAN_PATTERNS[currentLang] || SELIAN_PATTERNS.es;

      // Saludo
      if (p.greeting.test(text)) {
        return t('selianGreetReply');
      }

      // Ayuda
      if (p.help.test(text)) {
        return t('selianHelp');
      }

      // Estadísticas
      if (p.stats.test(text)) {
        const s = computeStats();
        setTimeout(() => { statsStartBtn.click(); }, 400);
        return t('selianStatsIntro')(s, t('selianOpenStats'));
      }

      // Quiz
      if (p.quiz.test(text)) {
        setTimeout(() => quizStartBtn.click(), 400);
        return t('selianQuizGo');
      }

      // Término aleatorio
      if (p.random.test(text)) {
        const foundTerm = glossary[Math.floor(Math.random() * glossary.length)];
        const idx = glossary.indexOf(foundTerm);
        setTimeout(() => showEntry(idx), 300);
        return t('selianRandomIntro')(foundTerm, foundTerm[`def_${currentLang}`] || foundTerm.def_es);
      }

      // Diferencia entre X y Y
      const diffMatch = rawText.match(p.diff);
      if (diffMatch) {
        const a = veraFindTerm(diffMatch[1]);
        const b = veraFindTerm(diffMatch[2]);
        if (a && b) {
          const defA = a[`def_${currentLang}`] || a.def_es;
          const defB = b[`def_${currentLang}`] || b.def_es;
          return `<strong>${a[`term_${currentLang}`] || a.term_es}:</strong> ${defA}<br><br><strong>${b[`term_${currentLang}`] || b.term_es}:</strong> ${defB}`;
        }
        if (!a) return t('selianDiffNotFound')(diffMatch[1].trim());
        if (!b) return t('selianDiffNotFound')(diffMatch[2].trim());
      }

      // Pronunciación
      if (p.pronounce.test(text)) {
        const cleaned = rawText.replace(p.pronounceClean, '').trim();
        const foundTerm = veraFindTerm(cleaned);
        if (foundTerm) {
          setTimeout(() => showEntry(glossary.indexOf(foundTerm)), 300);
          return t('selianPronounceResult')(foundTerm);
        }
        return t('selianPronounceAsk');
      }

      // Qué es X / definición directa
      const queMatch = rawText.match(p.whatIs) || rawText.match(p.define);
      const candidate = queMatch ? queMatch[1].replace(/\?/g, '').trim() : rawText;
      const direct = veraFindTerm(candidate);
      if (direct) {
        setTimeout(() => showEntry(glossary.indexOf(direct)), 300);
        return t('selianDefResult')(direct, direct[`def_${currentLang}`] || direct.def_es);
      }

      // Búsqueda difusa como último recurso
      const matches = veraFindAllMatches(rawText);
      if (matches.length) {
        return t('selianNoExactSuggest') + veraSuggestionRow(matches);
      }

      return t('selianNoMatch');
    }

    function openVera() {
      veraPanel.classList.add('open');
      if (!veraMessages.children.length) {
        veraAddMessage('bot', t('selianGreetPanel'));
      }
      veraInput.focus();
    }
    function closeVera() {
      veraPanel.classList.remove('open');
    }

    veraFab.addEventListener('click', () => {
      veraPanel.classList.contains('open') ? closeVera() : openVera();
    });
    veraClose.addEventListener('click', closeVera);

    veraForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const val = veraInput.value.trim();
      if (!val) return;
      veraAddMessage('user', val);
      veraInput.value = '';
      setTimeout(() => {
        veraAddMessage('bot', veraRespond(val));
      }, 250);
    });

    veraMessages.addEventListener('click', (e) => {
      const chip = e.target.closest('.vera-chip');
      if (chip) {
        showEntry(parseInt(chip.dataset.goto));
        closeVera();
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeVera();
    });

    // ── SELECTOR DE IDIOMA DE LA INTERFAZ ─────────────
    const langSwitchBtns = document.querySelectorAll('.lang-switch-btn');

    function setLang(lang) {
      currentLang = lang;
      try { localStorage.setItem('glosario-ui-lang', lang); } catch (e) {}

      langSwitchBtns.forEach(b => b.classList.toggle('active', b.dataset.lang === lang));
      applyI18n();
      filterTerms();

      if (currentEntryIndex !== null && entryView.style.display !== 'none') {
        showEntry(currentEntryIndex);
      }
      if (statsView.style.display !== 'none') {
        renderStats();
      }
      if (quizOverlay.classList.contains('open') && quizIndex < quizPool.length) {
        renderQuiz();
      }
      if (addOverlay.classList.contains('open')) {
        renderAddForm();
      }
      if (veraPanel.classList.contains('open')) {
        veraInput.placeholder = t('selianPlaceholder');
      }
    }

    langSwitchBtns.forEach(btn => {
      btn.addEventListener('click', () => setLang(btn.dataset.lang));
    });

    // ── INICIALIZACIÓN ────────────────────────────────
    loadStoredTerms();
    renderTermList();
    langSwitchBtns.forEach(b => b.classList.toggle('active', b.dataset.lang === currentLang));
    applyI18n();
  </script>
</body>
</html>
